{
  "buildCommand": "cd frontend && npm install && npx expo export --platform web",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "installCommand": "echo 'skip root install'",
  "rewrites": [
    {
      "source": "/api/proxy/:path*",
      "destination": "/api/backend?path=/:path*"
    }
  ]
}
